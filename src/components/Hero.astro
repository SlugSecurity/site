---
import { site, links } from '@/consts'
---

<section class="relative pt-16 pb-20 sm:pt-24 sm:pb-28">
	<div class="container-tight text-center">
		<h1 class="brand text-5xl sm:text-7xl md:text-8xl leading-[0.9] mb-3">
			{site.name}
		</h1>
		<p class="text-(--color-fg-dim) text-base sm:text-lg max-w-xl mx-auto mb-4 leading-relaxed">
			The student-run cybersecurity org at UC Santa Cruz.
		</p>
		<div class="flex flex-wrap items-center justify-center gap-3">
			<a href="/join" class="btn btn-primary">Join Slug Security</a>
			<a href={links.discord} class="btn">Discord</a>
		</div>
	</div>
</section>
