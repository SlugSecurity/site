---
import { getAllPosts, getExcerpt } from '@/lib/posts'

const recent = (await getAllPosts()).slice(0, 4)

function fmtDate(d: Date) {
	return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
}
---

<section class="max-w-7xl mx-auto px-5 mt-24">
	<div class="text-center mb-8">
		<h2 class="text-3xl sm:text-4xl mb-1">Recent posts</h2>
		<p class="text-(--color-fg-dim) text-sm">Writeups, club news, and other things members published.</p>
	</div>

	{recent.length === 0 ? (
		<div class="panel font-mono text-sm text-(--color-fg-dim) text-center">
			No posts yet.
		</div>
	) : (
		<div class="flex flex-col gap-2">
			{recent.map(p => {
				const excerpt = getExcerpt(p)
				return (
					<a href={`/posts/${p.id}`} class="panel panel-link group p-4 flex flex-col gap-1.5">
						<div class="flex flex-col sm:flex-row sm:items-baseline gap-x-4 gap-y-1.5">
							<h3 class="text-base leading-snug flex-1 min-w-0 sm:truncate group-hover:text-(--color-accent) transition-colors">
								{p.data.title}
							</h3>
							<div class="flex flex-wrap items-center gap-x-2.5 gap-y-1 shrink-0 label-sm">
								{p.data.tags.slice(0, 3).map(t => (
									<span class:list={[
										'border px-1.5 py-0.5',
										t === 'writeup'
											? 'text-(--color-accent) border-(--color-accent-dim)'
											: 'text-(--color-fg-faint) border-(--color-line)',
									]}>
										{t}
									</span>
								))}
								{p.data.authors.length > 0 && (
									<span class="text-(--color-fg-faint)">{p.data.authors.join(', ')}</span>
								)}
								<time class="text-(--color-fg-faint) tabular-nums" datetime={p.data.date.toISOString()}>{fmtDate(p.data.date)}</time>
							</div>
						</div>
						{excerpt && (
							<p class="text-sm text-(--color-fg-dim) line-clamp-1">
								{excerpt}
							</p>
						)}
					</a>
				)
			})}
		</div>
	)}

	<div class="text-center mt-6">
		<a href="/posts" class="label-sm text-(--color-fg-dim) hover:text-(--color-fg) link-arrow"><span class="link" data-scramble>View all posts</span></a>
	</div>
</section>
