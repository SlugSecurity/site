---
import { getAllPosts, getExcerpt } from '@/lib/posts'

const recent = (await getAllPosts()).slice(0, 4)

function fmtDate(d: Date) {
	return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })
}
---

<section class="container-tight mt-24">
	<div class="text-center mb-8">
		<h2 class="text-3xl sm:text-4xl mb-1">Recent posts</h2>
		<p class="text-(--color-fg-dim) text-sm">Writeups, club news, and other things members published.</p>
	</div>

	{recent.length === 0 ? (
		<div class="panel font-mono text-sm text-(--color-fg-dim) text-center">
			No posts yet.
		</div>
	) : (
		<div class="grid sm:grid-cols-2 gap-4">
			{recent.map(p => {
				const excerpt = getExcerpt(p)
				return (
					<a href={`/posts/${p.id}`} class="panel panel-link group">
						<div class="flex items-center justify-between gap-3 label-sm text-(--color-fg-faint) mb-2">
							<time datetime={p.data.date.toISOString()}>{fmtDate(p.data.date)}</time>
							{p.data.authors.length > 0 && (
								<span>{p.data.authors.join(', ')}</span>
							)}
						</div>
						<h3 class="text-lg leading-snug mb-2 group-hover:text-(--color-accent) transition-colors">
							{p.data.title}
						</h3>
						{excerpt && (
							<p class="text-sm text-(--color-fg-dim) leading-relaxed line-clamp-3 mb-3">
								{excerpt}
							</p>
						)}
						{p.data.tags.length > 0 && (
							<div class="flex flex-wrap gap-1.5">
								{p.data.tags.slice(0, 4).map(t => (
									<span class:list={[
										'label-sm border px-1.5 py-0.5',
										t === 'writeup'
											? 'text-(--color-accent) border-(--color-accent-dim)'
											: 'text-(--color-fg-faint) border-(--color-line)',
									]}>
										{t}
									</span>
								))}
							</div>
						)}
					</a>
				)
			})}
		</div>
	)}

	<div class="text-center mt-6">
		<a href="/posts" class="label-sm text-(--color-fg-dim) hover:text-(--color-fg) link-arrow"><span class="link" data-scramble>View all posts</span></a>
	</div>
</section>
